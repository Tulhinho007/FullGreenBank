# ─── Supabase PostgreSQL (PgBouncer - Transaction Mode) ───────────────────────
# Use a porta 6543 com ?pgbouncer=true para produção
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"

# ─── Supabase PostgreSQL (Session Mode) ───────────────────────────────────────
# Use a porta 5432 para rodar migrations (prisma migrate)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="troque-por-uma-string-longa-e-aleatória-em-produção"
JWT_EXPIRES_IN="7d"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS - URL do Frontend ───────────────────────────────────────────────────
# Em produção: URL do seu projeto frontend na Vercel
CLIENT_URL="http://localhost:5173"
