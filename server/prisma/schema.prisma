// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  MASTER
  ADMIN
  TESTER
  MEMBRO
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  username  String   @unique
  password  String
  role      UserRole @default(MEMBRO)
  active    Boolean  @default(true)
  isTipster Boolean  @default(false)
  
  // Settings & Preferences
  plan              String   @default("STARTER") // STARTER, STANDARD, PRO
  value             Float?
  payMethod         String?
  purchaseDate      String?                      // Data da compra (YYYY-MM-DD)
  lastPaymentDate   String?                      // Data do último pagamento (YYYY-MM-DD)
  dueDate           String?                      // Data de vencimento (YYYY-MM-DD)
  paymentStatus     String   @default("PENDENTE") // ATIVO, PENDENTE, ATRASADO, CANCELADO
  isActive          Boolean  @default(false)     // Acesso liberado?
  notes            String?  @db.Text
  
  currency          String   @default("BRL")     // BRL, USD, EUR
  language          String   @default("PT-BR")   // PT-BR, EN-US, ES-ES
  theme             String   @default("DARK")    // LIGHT, DARK, SYSTEM
  twoFactorEnabled  Boolean  @default(false)
  avatarUrl        String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tips                 Tip[]
  bancaContratos       BancaContrato[]
  bancaCarteiras       BancaCarteira[]
  solicitacoesInv      SolicitacaoInvestimento[]
  saques               Saque[]

  @@map("users")
}

model Tip {
  id          String   @id @default(uuid())
  title       String
  description String
  sport       String
  event       String
  market      String
  odds        Float
  stake       Float    // unidades
  result      String?  // GREEN, RED, VOID, PENDING
  profit      Float?
  valorCashout Float?
  tipDate     DateTime
  mercados    String[] @default([])
  isMultipla  Boolean  @default(false)
  jogos       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("tips")
}

model BancaContrato {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId         String?
  parent           BancaContrato?  @relation("SubContratos", fields: [parentId], references: [id])
  subContratos     BancaContrato[] @relation("SubContratos")

  identificacao    String?   @db.VarChar(50)

  dataInicial      DateTime  @default(now())
  dataFinal        DateTime?

  bancaInicial     Decimal   @db.Decimal(10, 2)
  bancaFinal       Decimal   @db.Decimal(10, 2)
  comissaoPercent  Decimal   @default(10) @db.Decimal(5, 2)

  // ATIVO | AGUARDANDO_SAQUE | FINALIZADO | ENCERRADO | CANCELADO
  status           String    @default("ATIVO")

  // FIM_DO_PRAZO | CLIENTE_ENCERROU | STOP_LOSS | META_ATINGIDA | SAQUE_TOTAL | CANCELADO | OUTRO
  motivoFim        String?

  observacoes      String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("banca_contratos")
}

model BancaCarteira {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  nome           String            @db.VarChar(100)
  casaAposta     String            
  
  bancaInicial   Decimal           @db.Decimal(10, 2) @default(0)
  perfilRisco    String            @default("moderado")
  
  itens          GestaoBancaItem[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("banca_carteiras")
}

model GestaoBancaItem {
  id             String         @id @default(uuid())
  carteiraId     String?
  carteira       BancaCarteira? @relation(fields: [carteiraId], references: [id], onDelete: Cascade)
  dataReferencia DateTime @db.Date // Salva apenas a data (YYYY-MM-DD)
  
  deposito       Decimal  @default(0) @db.Decimal(10, 2)
  saque          Decimal  @default(0) @db.Decimal(10, 2)
  resultado      Decimal  @default(0) @db.Decimal(10, 2)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("gestao_banca_itens")
}

model SupportTicket {
  id          String   @id @default(uuid())
  type        String   // bug, feedback
  title       String
  description String   @db.Text
  priority    String?  // low, medium, high, critical
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  
  // User info (optional if public)
  userEmail   String?
  userId      String?
  
  adminResponse String?   @db.Text
  respondedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_tickets")
}

model SolicitacaoInvestimento {
  id           String   @id @default(uuid())
  userId       String
  usuario      User     @relation(fields: [userId], references: [id])
  valorAporte  Float
  dataPedido   DateTime @default(now())
  status       String   @default("EM_ANALISE") // "EM_ANALISE", "ACEITO", "RECUSADO"
  termoAceito  Boolean  @default(true)
  observacoes  String?  @db.Text

  @@map("solicitacoes_investimento")
}

model Saque {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grossValue       Float
  comissionPercent Float
  netValue         Float
  method           String
  status           String   @default("PENDENTE") // CONCLUIDO, PENDENTE, PROCESSANDO, REJEITADO
  rejectionReason  String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("saques")
}

// ── Módulo Cadastros ──────────────────────────────────────────────────────────

model Sport {
  id    String  @id @default(cuid())
  name  String
  emoji String?
  slug  String  @unique

  @@map("sports")
}

model League {
  id       String  @id @default(cuid())
  name     String
  category String
  featured Boolean @default(false)

  @@map("leagues")
}

model Bookmaker {
  id           String @id @default(cuid())
  name         String @unique
  differential String @default("")
  focus        String @default("")

  @@map("bookmakers")
}

model Market {
  id        String @id @default(cuid())
  name      String
  sportSlug String @default("futebol")
  
  @@unique([name, sportSlug])
  @@map("markets")
}

model CustomTeam {
  id    String @id @default(cuid())
  name  String
  group String

  @@map("custom_teams")
}
