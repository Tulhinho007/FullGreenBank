// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  MASTER
  ADMIN
  MEMBRO
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  username  String   @unique
  password  String
  role      UserRole @default(MEMBRO)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tips                 Tip[]
  bancaContratos       BancaContrato[]
  bancaCarteiras       BancaCarteira[]

  @@map("users")
}

model Tip {
  id          String   @id @default(uuid())
  title       String
  description String
  sport       String
  event       String
  market      String
  odds        Float
  stake       Float    // unidades
  result      String?  // GREEN, RED, VOID, PENDING
  profit      Float?
  tipDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("tips")
}

model BancaContrato {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId         String?
  parent           BancaContrato?  @relation("SubContratos", fields: [parentId], references: [id])
  subContratos     BancaContrato[] @relation("SubContratos")

  identificacao    String?   @db.VarChar(50)

  dataInicial      DateTime  @default(now())
  dataFinal        DateTime?

  bancaInicial     Decimal   @db.Decimal(10, 2)
  bancaFinal       Decimal   @db.Decimal(10, 2)
  comissaoPercent  Decimal   @default(10) @db.Decimal(5, 2)

  // ATIVO | AGUARDANDO_SAQUE | FINALIZADO | ENCERRADO | CANCELADO
  status           String    @default("ATIVO")

  // FIM_DO_PRAZO | CLIENTE_ENCERROU | STOP_LOSS | META_ATINGIDA | SAQUE_TOTAL | CANCELADO | OUTRO
  motivoFim        String?

  observacoes      String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("banca_contratos")
}

model BancaCarteira {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  nome           String            @db.VarChar(100)
  casaAposta     String            
  
  bancaInicial   Decimal           @db.Decimal(10, 2) @default(0)
  perfilRisco    String            @default("moderado")
  
  itens          GestaoBancaItem[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("banca_carteiras")
}

model GestaoBancaItem {
  id             String         @id @default(uuid())
  carteiraId     String?
  carteira       BancaCarteira? @relation(fields: [carteiraId], references: [id], onDelete: Cascade)
  dataReferencia DateTime @db.Date // Salva apenas a data (YYYY-MM-DD)
  
  deposito       Decimal  @default(0) @db.Decimal(10, 2)
  saque          Decimal  @default(0) @db.Decimal(10, 2)
  resultado      Decimal  @default(0) @db.Decimal(10, 2)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("gestao_banca_itens")
}
