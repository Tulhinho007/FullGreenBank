// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  MASTER
  ADMIN
  TESTER
  MEMBRO
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      UserRole @default(MEMBRO)
  active    Boolean  @default(true)
  isTipster Boolean  @default(false)

  // Settings & Preferences
  plan              String   @default("STARTER") // STARTER, STANDARD, PRO
  value             Float?
  payMethod         String?
  purchaseDate      String?                      // Data da compra (YYYY-MM-DD)
  lastPaymentDate   String?                      // Data do último pagamento (YYYY-MM-DD)
  dueDate           String?                      // Data de vencimento (YYYY-MM-DD)
  paymentStatus     String   @default("PENDENTE") // ATIVO, PENDENTE, ATRASADO, CANCELADO
  isActive          Boolean  @default(false)     // Acesso liberado?
  notes             String?  @db.Text

  currency          String   @default("BRL")     // BRL, USD, EUR
  language          String   @default("PT-BR")   // PT-BR, EN-US, ES-ES
  theme             String   @default("DARK")    // LIGHT, DARK, SYSTEM
  twoFactorEnabled  Boolean  @default(false)
  avatarUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tips              Tip[]

  bancaCarteiras    BancaCarteira[]
  solicitacoesInv   SolicitacaoInvestimento[]
  contratos         Contrato[]

  permissions       UserPermission[]

  @@map("users")
}

model Tip {
  id           String   @id @default(uuid())
  title        String
  description  String
  sport        String
  event        String
  market       String
  odds         Float
  stake        Float    // unidades
  result       String?  // GREEN, RED, VOID, PENDING
  profit       Float?
  valorCashout Float?
  tipDate      DateTime
  mercados     String[] @default([])
  isMultipla   Boolean  @default(false)
  jogos        Json?
  linkAposta   String?     //
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("tips")
}



model Contrato {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  dataInicio      DateTime  @default(now())
  valorContratado Float?
  comissaoPercent Float?    @default(10)
  status          String    @default("ABERTO") // ABERTO, FINALIZADO, CANCELADO

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("contratos")
}

model BancaCarteira {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  nome         String            @db.VarChar(100)
  casaAposta   String

  bancaInicial Decimal           @db.Decimal(10, 2) @default(0)
  perfilRisco  String            @default("moderado")

  itens        GestaoBancaItem[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("banca_carteiras")
}

model GestaoBancaItem {
  id             String         @id @default(uuid())
  carteiraId     String?
  carteira       BancaCarteira? @relation(fields: [carteiraId], references: [id], onDelete: Cascade)
  dataReferencia DateTime       @db.Date // Salva apenas a data (YYYY-MM-DD)

  deposito       Decimal  @default(0) @db.Decimal(10, 2)
  saque          Decimal  @default(0) @db.Decimal(10, 2)
  resultado      Decimal  @default(0) @db.Decimal(10, 2)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("gestao_banca_itens")
}

model SupportTicket {
  id          String   @id @default(uuid())
  type        String   // bug, feedback
  title       String
  description String   @db.Text
  priority    String?  // low, medium, high, critical
  status      String   @default("PENDING") // PENDING, OPEN, IN_PROGRESS, RESOLVED

  // User info (optional if public)
  userEmail   String?
  userId      String?

  adminResponse String?   @db.Text
  respondedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_tickets")
}

model SolicitacaoInvestimento {
  id           String   @id @default(uuid())
  userId       String
  usuario      User     @relation(fields: [userId], references: [id])
  valorAporte  Float
  dataPedido   DateTime @default(now())
  status       String   @default("EM_ANALISE") // "EM_ANALISE", "ACEITO", "RECUSADO"
  termoAceito  Boolean  @default(true)
  observacoes  String?  @db.Text

  @@map("solicitacoes_investimento")
}



// ── Módulo Cadastros ──────────────────────────────────────────────────────────

model Sport {
  id    String  @id @default(cuid())
  name  String
  emoji String?
  slug  String  @unique

  @@map("sports")
}

model League {
  id       String  @id @default(cuid())
  name     String
  category String
  featured Boolean @default(false)

  @@map("leagues")
}

model Bookmaker {
  id           String @id @default(cuid())
  name         String @unique
  differential String @default("")
  focus        String @default("")

  @@map("bookmakers")
}

model Market {
  id        String @id @default(cuid())
  name      String
  sportSlug String @default("futebol")

  @@unique([name, sportSlug], name: "name_sportSlug")
  @@map("markets")
}

model CustomTeam {
  id    String @id @default(cuid())
  name  String
  group String

  @@map("custom_teams")
}

// ── Módulo Futevôlei ──────────────────────────────────────────────────────────

model FutvoleiMatch {
  id           String    @id @default(uuid())
  player1      String                         // Dupla A — Jogador 1
  player2      String                         // Dupla A — Jogador 2
  player3      String                         // Dupla B — Jogador 1
  player4      String                         // Dupla B — Jogador 2
  stake        Float                          // Valor da aposta
  totalSets    Int       @default(3)          // Ex: Melhor de 3
  pointsPerSet Int       @default(18)         // Pontos por set
  scoreA       Int       @default(0)          // Placar Dupla A
  scoreB       Int       @default(0)          // Placar Dupla B
  status       String    @default("PENDING")  // PENDING, FINISHED, CANCELED
  winnerTeam   Int?                           // 1 = Dupla A, 2 = Dupla B
  finishedAt   DateTime?                      // Data/hora de finalização
  createdAt    DateTime  @default(now())

  @@map("futvolei_matches")
}
model UserPermission {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     String
  pageName   String
  pageLabel  String
  canView    Boolean  @default(false)
  canEdit    Boolean  @default(false)
  canDelete  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, pageName])
  @@map("user_permissions")
}
model SecurityLog {
  id         String   @id @default(uuid())
  ip         String
  route      String
  method     String
  statusCode Int
  userId     String?
  userAgent  String?
  reason     String?  // ex: "LOGIN_FAILED", "RATE_LIMIT", "UNAUTHORIZED"
  createdAt  DateTime @default(now())

  @@map("security_logs")
}
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  userEmail String
  userName  String
  userRole  String
  category  String
  action    String
  detail    String   @db.Text
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model Transacao {
  id        String   @id @default(uuid())
  date      String
  type      String   // DEPOSITO | SAQUE
  userId    String
  userName  String
  value     Float
  method    String
  status    String   @default("CONCLUIDO") // CONCLUIDO | PENDENTE | RECUSADO
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transacoes")
}